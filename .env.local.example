# Rule34 API Configuration
# To use Rule34 API, you need to create an account and get an API key
# URL: https://rule34.xxx/index.php?page=account&s=options

# Your Rule34 API Key
RULE34_API_KEY=your_api_key_here

# Your Rule34 User ID
RULE34_USER_ID=your_user_id_here

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# SERVICE_ROLE_KEY is needed for the seed script to bypass RLS policies
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
