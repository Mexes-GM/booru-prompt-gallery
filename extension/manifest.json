{
  "manifest_version": 3,
  "name": "Booru Prompt Gallery Sidebar",
  "version": "1.0.0",
  "description": "A pocket prompt assistant wrapper for Booru Prompt Gallery",
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Prompt Gallery Sidebar"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
