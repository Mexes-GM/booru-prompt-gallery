{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "functions": {
    "app/api/**/*": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=300, stale-while-revalidate=600"
        }
      ]
    },
    {
      "source": "/(favicon\\.ico|favicon\\.png|icon\\.png|manifest\\.json)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ],
  "env": {
    "NEXT_PUBLIC_APP_URL": "",
    "NEXT_PUBLIC_APP_VERSION": "@sentry/nextjs:version",
    "API_BASE_URL": "",
    "API_KEY": "",
    "NEXT_PUBLIC_SENTRY_DSN": "@sentry/nextjs:dsn",
    "SENTRY_ORG": "boorupromptgallery",
    "SENTRY_PROJECT": "sentry-fulvous-anchor",
    "SENTRY_AUTH_TOKEN": "@sentry/nextjs:auth_token"
  }
}
