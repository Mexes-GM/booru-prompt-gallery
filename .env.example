# ---- Base ----
NEXT_PUBLIC_APP_URL=https://booru-prompt-gallery.com
# CF Worker — handles image proxy AND API routes (/api/*)
# ⚠️ Leave EMPTY for local development. Set to your worker URL in production.
NEXT_PUBLIC_IMAGE_PROXY_URL=

# AWS CloudFront distribution fronting cdn.donmai.us (Danbooru image bytes).
# When set, Danbooru images load through CloudFront (edge cache + Referer
# injection) instead of /api/download — keeps image bandwidth off Netlify/Vercel.
# Leave EMPTY to fall back to /api/download. See docs/image-proxy-migration-plan.md.
NEXT_PUBLIC_CDN_PROXY_URL=

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_JWT_SECRET=...

# ---- PostgreSQL (Supabase) ----
POSTGRES_HOST=db.your-project.supabase.co
POSTGRES_DATABASE=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=...
POSTGRES_URL=postgres://...
POSTGRES_PRISMA_URL=postgres://...
POSTGRES_URL_NON_POOLING=postgres://...

# ---- API Keys ----
# Danbooru (opcional pero recomendado)
DANBOORU_USERNAME=your_username
DANBOORU_API_KEY=your_api_key

# Rule34
RULE34_USER_ID=your_user_id
RULE34_API_KEY=your_api_key

# Gelbooru
GELBOORU_USER_ID=your_user_id
GELBOORU_API_KEY=your_api_key

# ---- AI / LLM (para clasificación de tags) ----
OPENROUTER_API_KEY=sk-or-v1-...
DEEPSEEK_API_KEY=sk-...

# ---- Feedback (Discord webhook) ----
DISCORD_FEEDBACK_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ---- Analytics: Cloudflare Web Analytics (privacy-friendly, works on Netlify) ----
# Cloudflare dashboard → Analytics & Logs → Web Analytics → Add a site → copy the
# beacon token here. Falls back to no-op if undefined.
NEXT_PUBLIC_CF_BEACON_TOKEN=

# ---- Analytics: Vercel Web Analytics ----
# Replaces @vercel/analytics, which only reports data on Vercel deployments.
# It is injected automatically by Vercel if configured.

# ---- Analytics: PostHog Product Analytics ----
# For advanced event tracking, heatmaps, and feature usage.
# PostHog dashboard → Project Settings → Project API Key & Instance URL
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---- PostHog: error tracking source maps (production builds only) ----
# Lets PostHog un-minify stack traces (real file/function names instead of
# "n", "?", chunk offsets). Without these two, the build skips source map
# upload entirely — no effect on local dev.
#   POSTHOG_API_KEY: Personal API key with "write" access on Error Tracking
#     → PostHog dashboard → Settings → Personal API Keys
#   POSTHOG_PROJECT_ID: Numeric project ID
#     → PostHog dashboard → Project Settings → Project ID
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID=

# ---- Image optimization: weserv.nl resize + AVIF/WebP (opt-in) ----
# Set to 1 to route publicly-fetchable images (Aibooru, e621) through
# images.weserv.nl for resizing and WebP/AVIF conversion. Free, no signup.
# Danbooru/Gelbooru are never routed through weserv (WAF / hotlink protection).
NEXT_PUBLIC_WESERV_ENABLED=

# ---- Anti-abuse: Cloudflare Turnstile (feedback form CAPTCHA) ----
# Cloudflare dashboard → Turnstile → add a widget. Site key is public (client),
# secret key is server-side. When unset, the feedback form works without a
# challenge and server verification is skipped (graceful fallback).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# NOTE: in production the feedback POST hits the Cloudflare Worker, so also set
# the secret there:  wrangler secret put TURNSTILE_SECRET_KEY

# ---- Anti-abuse: gate the FREE AI prompt-convert tier behind Turnstile (F2) ----
# The free AI tier (/api/llm/convert with provider=cloudflare) spends OUR shared
# Cloudflare Workers AI quota. Setting this flag to "1" ON THE WORKER makes that
# tier require a valid Turnstile token (the paid tier / user's own API key is
# never challenged). Decoupled from TURNSTILE_SECRET_KEY so enabling feedback
# verification never breaks AI. Default (unset) = no gate.
#   Prereqs before enabling: NEXT_PUBLIC_TURNSTILE_SITE_KEY (client) +
#   TURNSTILE_SECRET_KEY (worker) must be set so the client sends tokens.
#   Enable with:  wrangler secret put TURNSTILE_AI_GATE   (value: 1)
# TURNSTILE_AI_GATE=

# ---- Anti-abuse: adaptive rate limits (anon vs. authenticated) (F4) ----
# When "1", logged-in users get a higher per-key allowance on the Danbooru hot
# path (keyed by verified Supabase user id) — anonymous traffic is UNCHANGED.
# Purely additive (nobody gets less) and fail-open: if the session can't be
# verified it silently falls back to anonymous limits. Default (unset) = off.
# Requires SUPABASE_JWT_SECRET (below) so the session JWT can be verified
# locally (HS256, no network call). No effect without it.
# ADAPTIVE_LIMITS=

# ---- Deployment status badges (/api/status) ----
# Powers the Vercel/Netlify "Operational" badges under the social links.
# UptimeRobot dashboard → My Settings → API → "Read-Only API Key".
# When unset, the route falls back to live health pings of each deployment
# (works out of the box, just less authoritative). Optional friendly-name
# overrides let you map monitors explicitly instead of matching by URL host.
UPTIMEROBOT_API_KEY=
UPTIMEROBOT_VERCEL_NAME=
UPTIMEROBOT_NETLIFY_NAME=

# ---- Sentry (error tracking) ----
NEXT_PUBLIC_SENTRY_DSN=https://...@....ingest.us.sentry.io/...
SENTRY_AUTH_TOKEN=...
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project
SENTRY_PUBLIC_KEY=...
SENTRY_OTLP_TRACES_URL=https://...ingest.us.sentry.io/api/.../integration/otlp/v1/traces
SENTRY_VERCEL_LOG_DRAIN_URL=https://...ingest.us.sentry.io/api/.../integration/vercel/logs/

# ---- Admin ----
ADMIN_PASSWORD=change-me

# ---- Maintenance mode ----
# Set to 1 to take the app offline: "/" and "/extension" render a static
# "Deployment Paused" curtain instead of the app, and middleware blocks all
# other non-root routes (API, admin, etc.). Leave empty/unset to keep the app live.
MAINTENANCE_MODE=
